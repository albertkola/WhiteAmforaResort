---
import '../styles/global.css';
import { site } from '../config/site';
import { type Locale, defaultLocale, localizedPath } from '../i18n';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import WhatsAppBubble from '../components/layout/WhatsAppBubble.astro';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  /** Path without locale prefix, e.g. "/" or "/rooms" — used for hreflang + active nav. */
  path?: string;
  /** Header floats transparently over a dark hero, then turns solid on scroll. */
  overHero?: boolean;
}

const { title, description, locale, path = '/', overHero = false } = Astro.props;

const canonical = new URL(localizedPath(locale, path), Astro.site).toString();
const enHref = new URL(localizedPath('en', path), Astro.site).toString();
const sqHref = new URL(localizedPath('sq', path), Astro.site).toString();
---

<!doctype html>
<html lang={locale === defaultLocale ? 'en' : locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- hreflang alternates -->
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="sq" href={sqHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />

    <!-- icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph (expanded in the SEO increment) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-full focus:bg-clay focus:px-5 focus:py-2.5 focus:text-canvas"
    >
      Skip to content
    </a>

    <Header locale={locale} path={path} overHero={overHero} />

    <main id="main" class={overHero ? '' : 'pt-20 md:pt-24'}>
      <slot />
    </main>

    <Footer locale={locale} />
    <WhatsAppBubble locale={locale} />

    <!-- Scroll-reveal: adds .is-visible as elements enter the viewport -->
    <script>
      const items = document.querySelectorAll<HTMLElement>('[data-reveal]');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (reduce || !('IntersectionObserver' in window)) {
        items.forEach((el) => el.classList.add('is-visible'));
      } else {
        // index children within reveal-groups for stagger
        document.querySelectorAll('[data-reveal-group]').forEach((group) => {
          group.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el, i) => {
            el.style.setProperty('--reveal-i', String(i));
          });
        });

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
        );
        items.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomePlaceholder from '../../components/HomePlaceholder.astro';
import { useTranslations } from '../../i18n';

const locale = 'sq' as const;
const t = useTranslations(locale);
---

<BaseLayout title={t('meta.title')} description={t('meta.description')} locale={locale} path="/">
  <HomePlaceholder locale={locale} />
</BaseLayout>

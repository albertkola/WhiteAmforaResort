---
/**
 * Optimized image wrapper around Astro's <Picture> (astro:assets).
 * Emits AVIF + WebP with a fallback, responsive `srcset`, and intrinsic
 * dimensions to prevent layout shift. Pass a locally-imported image as `src`.
 *
 * `alt` is required (decorative images should pass alt="").
 */
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  widths?: number[];
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  aspect?: string; // e.g. "4/3", "16/9"
  class?: string;
  imgClass?: string;
}

const {
  src,
  alt,
  widths = [400, 640, 960, 1280, 1600],
  sizes = '100vw',
  loading = 'lazy',
  fetchpriority = 'auto',
  aspect,
  class: className = '',
  imgClass = '',
} = Astro.props;

const wrapperStyle = aspect ? `aspect-ratio:${aspect}` : undefined;
---

<figure class={`overflow-hidden ${className}`} style={wrapperStyle}>
  <Picture
    src={src}
    alt={alt}
    widths={widths}
    sizes={sizes}
    formats={['avif', 'webp']}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding="async"
    class={`h-full w-full object-cover ${imgClass}`}
  />
</figure>

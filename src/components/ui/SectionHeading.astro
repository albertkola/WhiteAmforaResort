---
/**
 * Section heading: eyebrow + title (+ optional intro).
 * Default heading level is h2; override with `as` for correct document outline.
 */
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  as?: 'h1' | 'h2' | 'h3';
  align?: 'left' | 'center';
  tone?: 'ink' | 'light';
  class?: string;
}

const {
  eyebrow,
  title,
  intro,
  as: Tag = 'h2',
  align = 'left',
  tone = 'ink',
  class: className = '',
} = Astro.props;

const alignCls = align === 'center' ? 'text-center mx-auto items-center' : 'text-left items-start';
const titleSize = Tag === 'h1' ? 'text-hero' : 'text-display';
const introTone = tone === 'light' ? 'text-canvas/80' : 'text-ink-soft';
const eyebrowTone = tone === 'light' ? 'text-brass' : 'text-clay';
---

<div class={['flex flex-col', alignCls, className].join(' ')} data-reveal>
  {eyebrow && (
    <span class={`text-eyebrow font-medium uppercase ${eyebrowTone}`} style="letter-spacing:.18em">
      {eyebrow}
    </span>
  )}
  <Tag class={`mt-3 font-display ${titleSize} font-light`}>{title}</Tag>
  {intro && <p class={`mt-5 max-w-prose text-lg/relaxed ${introTone}`}>{intro}</p>}
</div>

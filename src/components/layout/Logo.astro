---
/** Amphora line-mark. Inherits color via currentColor. */
interface Props {
  class?: string;
}
const { class: className = 'h-7 w-7' } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 32 32"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  role="img"
  aria-hidden="true"
>
  <path d="M13 7c0 2 1.5 2.5 1.5 4S11 14 11 18c0 4 2.2 7 5 7s5-3 5-7c0-4-3.5-5.5-3.5-7S19 9 19 7" />
  <path d="M12.5 7h7" />
  <path d="M14.5 25h3" />
</svg>

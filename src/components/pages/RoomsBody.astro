---
import { type Locale, useTranslations, useList, localizedPath } from '../../i18n';
import { site, whatsappLink } from '../../config/site';
import PageHero from '../ui/PageHero.astro';
import Section from '../ui/Section.astro';
import Picture from '../ui/Picture.astro';
import Button from '../ui/Button.astro';

import heroImg from '../../assets/photos/balcony-doors.jpg';
import g1 from '../../assets/photos/apartment-interior.jpg';
import g2 from '../../assets/photos/balcony-curtains.jpg';
import g3 from '../../assets/photos/beach-cove2.jpg';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const amenities = useList(locale)<string>('rooms.unit.amenities');

const unitName = t('rooms.unit.name');
const inquiryHref = `${localizedPath(locale, '/contact')}?room=${encodeURIComponent(unitName)}`;
const waHref = whatsappLink(t('rooms.unit.wa'));
---

<PageHero
  tag={t('rooms.hero.tag')}
  title={t('rooms.hero.title')}
  subtitle={t('rooms.hero.subtitle')}
  image={heroImg}
  alt={t('rooms.alt.hero')}
/>

<Section bg="canvas" width="default">
  <p class="max-w-prose text-lg/relaxed text-ink-soft" data-reveal>{t('rooms.intro')}</p>

  <!-- Featured apartment -->
  <div class="mt-12 grid items-start gap-10 lg:grid-cols-2 lg:gap-14">
    <div data-reveal>
      <Picture
        src={g1}
        alt={t('rooms.alt.g1')}
        widths={[480, 768, 1024, 1280]}
        sizes="(min-width:1024px) 48vw, 92vw"
        aspect="4/3"
        class="rounded-[1.75rem] shadow-xl shadow-ink/10"
      />
      <div class="mt-4 grid grid-cols-2 gap-4">
        <Picture src={g2} alt={t('rooms.alt.g2')} widths={[320, 480, 640]} sizes="(min-width:1024px) 24vw, 46vw" aspect="4/3" class="rounded-2xl shadow-lg shadow-ink/10" />
        <Picture src={g3} alt={t('rooms.alt.g3')} widths={[320, 480, 640]} sizes="(min-width:1024px) 24vw, 46vw" aspect="4/3" class="rounded-2xl shadow-lg shadow-ink/10" />
      </div>
    </div>

    <div class="lg:pt-2" data-reveal>
      <h2 class="font-display text-display font-light text-ink">{unitName}</h2>
      <p class="mt-2 text-sm font-medium tracking-wide text-sea">{t('rooms.unit.capacity')}</p>
      <p class="mt-5 max-w-prose text-ink-soft">{t('rooms.unit.description')}</p>

      <h3 class="mt-8 text-eyebrow font-semibold uppercase tracking-[.16em] text-clay">{t('rooms.unit.amenities_title')}</h3>
      <ul class="mt-4 grid grid-cols-1 gap-x-6 gap-y-2.5 sm:grid-cols-2">
        {amenities.map((a) => (
          <li class="flex items-center gap-2.5 text-ink">
            <svg class="shrink-0 text-clay" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
            {a}
          </li>
        ))}
      </ul>

      <div class="mt-9 flex flex-wrap gap-4">
        <Button variant="primary" href={inquiryHref}>{t('rooms.unit.cta')}</Button>
        <Button variant="outline" href={waHref} target="_blank" rel="noopener noreferrer">{t('rooms.unit.cta_whatsapp')}</Button>
      </div>
    </div>
  </div>
</Section>

<!-- More layouts coming -->
<Section bg="deep" width="default" padding="md">
  <div class="flex flex-col items-start gap-6 md:flex-row md:items-center md:justify-between" data-reveal>
    <div class="max-w-2xl">
      <h2 class="font-display text-title font-light text-ink">{t('rooms.more.title')}</h2>
      <p class="mt-3 text-ink-soft">{t('rooms.more.body')}</p>
    </div>
    <Button variant="primary" href={localizedPath(locale, '/contact')}>{t('rooms.more.cta')}</Button>
  </div>
</Section>

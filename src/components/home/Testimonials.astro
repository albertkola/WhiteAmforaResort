---
import { type Locale, useTranslations, useList } from '../../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const items = useList(locale)<{ quote: string; attribution: string }>('home.testimonials.items');
---

<section class="bg-sea py-20 text-canvas md:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <h2 class="max-w-2xl font-display text-display font-light" data-reveal>{t('home.testimonials.title')}</h2>

    <div class="mt-12 grid gap-10 md:grid-cols-3 md:gap-8" data-reveal-group>
      {items.map((item) => (
        <figure class="flex flex-col border-t border-canvas/20 pt-6" data-reveal>
          <span class="font-display text-5xl leading-none text-brass" aria-hidden="true">&ldquo;</span>
          <blockquote class="mt-3 text-lg/relaxed text-canvas/95">{item.quote}</blockquote>
          <figcaption class="mt-5 text-sm font-medium uppercase tracking-wider text-brass">
            {item.attribution}
          </figcaption>
        </figure>
      ))}
    </div>

    <p class="mt-10 max-w-prose text-sm text-canvas/80" data-reveal>{t('home.testimonials.note')}</p>
  </div>
</section>

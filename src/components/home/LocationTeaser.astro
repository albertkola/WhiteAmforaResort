---
import { type Locale, useTranslations, useList } from '../../i18n';
import { site } from '../../config/site';
import Picture from '../ui/Picture.astro';
import Button from '../ui/Button.astro';
import SocialIcon from '../layout/SocialIcon.astro';
import bayImg from '../../assets/photos/bay-overlook.jpg';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const distances = useList(locale)<{ label: string; value: string }>('home.location.items');
const hasEmbed = Boolean(site.mapEmbedUrl);
---

<section class="bg-canvas py-20 md:py-28 lg:py-32">
  <div class="mx-auto grid max-w-7xl items-center gap-10 px-6 lg:grid-cols-2 lg:gap-16">
    <div class="order-2 lg:order-1" data-reveal>
      <h2 class="font-display text-display font-light text-ink">{t('home.location.title')}</h2>
      <p class="mt-5 max-w-prose text-lg/relaxed text-ink-soft">{t('home.location.intro')}</p>

      <dl class="mt-8 grid grid-cols-2 gap-x-8 gap-y-6">
        {distances.map((d) => (
          <div class="border-t border-ink/10 pt-4">
            <dt class="text-sm text-ink-soft">{d.label}</dt>
            <dd class="mt-1 font-display text-2xl font-light text-clay">{d.value}</dd>
          </div>
        ))}
      </dl>

      <div class="mt-9">
        <Button variant="outline" href={site.mapLink} target="_blank" rel="noopener noreferrer">
          <SocialIcon name="map" class="h-4 w-4" /> {t('home.location.cta')}
        </Button>
      </div>
    </div>

    <div class="order-1 lg:order-2" data-reveal>
      {hasEmbed ? (
        <div class="overflow-hidden rounded-[1.75rem] shadow-xl shadow-ink/10" style="aspect-ratio:4/3">
          <iframe
            src={site.mapEmbedUrl}
            title={t('a11y.map')}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="h-full w-full border-0"
          ></iframe>
        </div>
      ) : (
        <Picture
          src={bayImg}
          alt={t('home.alt.location')}
          widths={[480, 768, 1024, 1280]}
          sizes="(min-width:1024px) 48vw, 92vw"
          aspect="4/3"
          class="rounded-[1.75rem] shadow-xl shadow-ink/10"
        />
      )}
    </div>
  </div>
</section>

---
import { type Locale, useTranslations, useList } from '../../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const items = useList(locale)<{ label: string; desc: string }>('home.highlights.items');

// Icons map to the confirmed items, in locale order:
// beach · balcony/sea view · kitchen · parking · wifi · airport
const icons = [
  '<path d="M3 19h18"/><path d="M5 19c1.5-5 5-8 9-8s5 1 7 3"/><circle cx="8" cy="6" r="2.5"/>',
  '<path d="M4 21V10l8-5 8 5v11"/><path d="M4 14h16"/><path d="M9 21v-4h6v4"/>',
  '<path d="M5 3v8m0 0a3 3 0 0 0 3-3V3M8 3v5M6.5 11v10"/><path d="M16 3c-1.5 1-2 3-2 5s.5 3 2 3v10"/>',
  '<rect x="4" y="4" width="16" height="16" rx="3"/><path d="M9 16V8h4a2.5 2.5 0 0 1 0 5H9"/>',
  '<path d="M2 8.5C6 5 18 5 22 8.5"/><path d="M5 12c4-3 10-3 14 0"/><path d="M8.5 15.5c2-1.5 5-1.5 7 0"/><circle cx="12" cy="19" r="1.2" fill="currentColor" stroke="none"/>',
  '<path d="M21 16v-2l-8-5V4a1.5 1.5 0 0 0-3 0v5l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-3.5z"/>',
];
---

<section class="bg-canvas-deep py-16 md:py-20">
  <div class="mx-auto max-w-7xl px-6">
    <h2 class="max-w-2xl font-display text-title font-light text-ink" data-reveal>{t('home.highlights.title')}</h2>

    <ul class="mt-10 grid gap-x-10 gap-y-10 sm:grid-cols-2 lg:grid-cols-3" data-reveal-group>
      {items.map((item, i) => (
        <li class="flex gap-4 border-t border-ink/10 pt-5" data-reveal>
          <span class="mt-0.5 shrink-0 text-clay" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons[i] ?? ''} />
          </span>
          <div>
            <h3 class="font-medium text-ink">{item.label}</h3>
            <p class="mt-1 text-sm/relaxed text-ink-soft">{item.desc}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
